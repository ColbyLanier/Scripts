#!/usr/bin/env python3
"""session-transcript — convert Claude Code JSONL to token-efficient transcript
Usage: session-transcript <session.jsonl> [--max-chars N]
Output: compact text transcript suitable for MiniMax summarization

TAGS: transcript,session,jsonl
AUDIENCE: mechanicus,operators
"""

import json
import sys
import os
import re
import argparse


MAX_TEXT_ITEM = 600     # chars per assistant text block
MAX_USER_MSG = 400      # chars per user message
MAX_RESULT_PREVIEW = 120  # chars of tool result to show
DEFAULT_MAX_CHARS = 4000  # total output cap


def truncate(s, n, suffix="…"):
    s = s.strip()
    if len(s) <= n:
        return s
    return s[:n] + suffix


def summarize_tool_use(name, inp):
    """Collapse a tool_use block to a one-liner."""
    if not inp:
        return f"[{name}]"

    # Key-specific pretty summaries
    if name in ("Read", "Write"):
        path = inp.get("file_path", "")
        path = os.path.basename(path) if path else ""
        limit = inp.get("limit", "")
        offset = inp.get("offset", "")
        extra = ""
        if offset or limit:
            extra = f" L{offset}" + (f"-{int(offset or 0)+int(limit or 0)}" if limit else "+")
        return f"[{name}: {path}{extra}]"

    if name == "Grep":
        pat = inp.get("pattern", "")[:40]
        path = os.path.basename(inp.get("path", ""))
        return f"[Grep: /{pat}/ in {path}]"

    if name == "Glob":
        return f"[Glob: {inp.get('pattern', '')}]"

    if name == "Edit":
        path = os.path.basename(inp.get("file_path", ""))
        return f"[Edit: {path}]"

    if name == "Bash":
        cmd = inp.get("command", "")[:60].strip()
        desc = inp.get("description", "")
        label = desc[:50] if desc else cmd
        return f"[Bash: {label}]"

    if name in ("TodoWrite", "TodoRead"):
        todos = inp.get("todos", [])
        return f"[{name}: {len(todos)} items]"

    if name == "WebFetch":
        url = inp.get("url", "")[:60]
        return f"[WebFetch: {url}]"

    if name == "WebSearch":
        return f"[WebSearch: {inp.get('query', '')[:50]}]"

    if name == "Agent":
        return f"[Agent: {inp.get('description', '')[:50]}]"

    if name == "Write":
        path = os.path.basename(inp.get("file_path", ""))
        return f"[Write: {path}]"

    # Fallback: first key=value pair
    first_key = next(iter(inp), None)
    if first_key:
        val = str(inp[first_key])[:40]
        return f"[{name}: {first_key}={val}]"
    return f"[{name}]"


def summarize_tool_result(content):
    """Collapse a tool_result content to a short preview."""
    if isinstance(content, list):
        texts = []
        for item in content:
            if isinstance(item, dict):
                t = item.get("text", "")
                if t:
                    texts.append(t)
        text = " ".join(texts)
    elif isinstance(content, str):
        text = content
    else:
        text = str(content)

    # Strip ANSI, excessive whitespace
    text = re.sub(r'\x1b\[[0-9;]*m', '', text)
    text = re.sub(r'\s+', ' ', text).strip()

    if not text:
        return "[Result: (empty)]"
    preview = truncate(text, MAX_RESULT_PREVIEW)
    return f"[Result: {preview}]"


def extract_user_content(content):
    """Extract human-readable content from a user message."""
    if isinstance(content, str):
        return truncate(content, MAX_USER_MSG)

    if isinstance(content, list):
        parts = []
        for item in content:
            if not isinstance(item, dict):
                continue
            itype = item.get("type")
            if itype == "text":
                text = item.get("text", "").strip()
                if text:
                    parts.append(truncate(text, MAX_USER_MSG))
            elif itype == "tool_result":
                # Inline tool result (response from a tool)
                parts.append(summarize_tool_result(item.get("content", "")))
        return "\n".join(parts) if parts else None

    return None


def extract_assistant_content(content):
    """Extract human-readable content from an assistant message."""
    if isinstance(content, str):
        return truncate(content, MAX_TEXT_ITEM)

    if isinstance(content, list):
        parts = []
        for item in content:
            if not isinstance(item, dict):
                continue
            itype = item.get("type")
            if itype == "text":
                text = item.get("text", "").strip()
                if text:
                    parts.append(truncate(text, MAX_TEXT_ITEM))
            elif itype == "thinking":
                pass  # skip internal thinking
            elif itype == "tool_use":
                name = item.get("name", "?")
                inp = item.get("input", {})
                parts.append(summarize_tool_use(name, inp))
        return "\n".join(parts) if parts else None

    return None


def parse_jsonl(path):
    """Yield (type, role, content_str) tuples from a session JSONL."""
    with open(path) as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                obj = json.loads(line)
            except json.JSONDecodeError:
                continue

            t = obj.get("type")

            if t == "summary":
                summary = obj.get("summary", "")
                if summary:
                    yield ("summary", None, truncate(summary, 300))

            elif t in ("user", "assistant"):
                msg = obj.get("message", {})
                role = msg.get("role", t)
                content = msg.get("content")

                if role == "user":
                    text = extract_user_content(content)
                else:
                    text = extract_assistant_content(content)

                if text:
                    yield ("message", role, text)


def build_transcript(path, max_chars=DEFAULT_MAX_CHARS):
    lines = []
    total = 0

    for kind, role, text in parse_jsonl(path):
        if kind == "summary":
            line = f"[SUMMARY: {text}]"
        elif role == "user":
            line = f"User: {text}"
        elif role == "assistant":
            line = f"Claude: {text}"
        else:
            continue

        if total + len(line) > max_chars:
            lines.append(f"[…transcript truncated at {max_chars} chars…]")
            break

        lines.append(line)
        total += len(line) + 1  # +1 for newline

    return "\n\n".join(lines)


def main():
    parser = argparse.ArgumentParser(
        description="Convert Claude Code JSONL session to compact transcript"
    )
    parser.add_argument("session", nargs="?", help="Path to session .jsonl file")
    parser.add_argument("--max-chars", type=int, default=DEFAULT_MAX_CHARS,
                        help=f"Output char limit (default: {DEFAULT_MAX_CHARS})")
    parser.add_argument("--list", action="store_true",
                        help="List recent sessions for current project")
    args = parser.parse_args()

    if args.list:
        cwd = os.getcwd()
        slug = cwd.replace("/", "-").replace("~", "").lstrip("-")
        project_dir = os.path.expanduser(f"~/.claude/projects/{slug}")
        if not os.path.isdir(project_dir):
            print(f"No project dir found: {project_dir}", file=sys.stderr)
            sys.exit(1)
        files = sorted(
            [f for f in os.listdir(project_dir) if f.endswith(".jsonl")],
            key=lambda f: os.path.getmtime(os.path.join(project_dir, f)),
            reverse=True
        )
        for i, f in enumerate(files[:10]):
            fpath = os.path.join(project_dir, f)
            size = os.path.getsize(fpath)
            mtime = os.path.getmtime(fpath)
            import datetime
            ts = datetime.datetime.fromtimestamp(mtime).strftime("%Y-%m-%d %H:%M")
            print(f"{ts}  {size:>8} B  {f}")
        return

    if not args.session:
        # Default: most recent session for cwd
        cwd = os.getcwd()
        slug = cwd.replace("/", "-").replace("~", "").lstrip("-")
        project_dir = os.path.expanduser(f"~/.claude/projects/{slug}")
        if not os.path.isdir(project_dir):
            print(f"No session file provided and no project dir found: {project_dir}", file=sys.stderr)
            parser.print_usage()
            sys.exit(1)
        files = sorted(
            [os.path.join(project_dir, f) for f in os.listdir(project_dir) if f.endswith(".jsonl")],
            key=os.path.getmtime, reverse=True
        )
        if not files:
            print("No session files found.", file=sys.stderr)
            sys.exit(1)
        path = files[0]
        print(f"# Session: {os.path.basename(path)}\n", file=sys.stderr)
    else:
        path = os.path.expanduser(args.session)

    if not os.path.exists(path):
        print(f"File not found: {path}", file=sys.stderr)
        sys.exit(1)

    transcript = build_transcript(path, args.max_chars)
    print(transcript)


if __name__ == "__main__":
    main()
