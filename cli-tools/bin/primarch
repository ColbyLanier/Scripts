#!/usr/bin/env bash
# Primarch Launcher - Start Claude sessions with persona identity and session doc
# TAGS: instance, vault-mind, primarch
# AUDIENCE: user
#
# Usage: primarch <name> [claude-flags...]
#        primarch list
#        primarch info <name>
#
# Examples:
#   primarch vulkan                    # Launch as Vulkan
#   primarch fg                        # Launch as Fabricator-General
#   primarch vulkan -p "do the thing"  # Non-interactive with persona
#   primarch list                      # Show all primarchs

set -euo pipefail

REGISTRY_FILE="${PRIMARCH_REGISTRY:-$HOME/.claude/primarchs.json}"
API_URL="${TOKEN_API_URL:-http://100.95.109.23:7777}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

usage() {
    cat << 'EOF'
Primarch Launcher - Start Claude sessions with persona identity

Usage:
  primarch <name> [claude-flags...]    Launch Claude as a Primarch
  primarch list                        List all registered Primarchs
  primarch info <name>                 Show Primarch details

Primarchs:
  Each Primarch has an identity, a vault domain, and a linked session doc
  managed via the token-api. The identity is injected via --append-system-prompt
  and the vault-mind skill loads the session doc on startup.

Aliases:
  Short names are supported (e.g., 'fg' for 'fabricator-general').

Examples:
  primarch vulkan                      Interactive session as Vulkan
  primarch fg                          Interactive session as Fabricator-General
  primarch vulkan --model sonnet       Use specific model
  primarch fg -p "check fleet status"  Non-interactive
EOF
    exit 0
}

# Ensure registry exists
ensure_registry() {
    if [[ ! -f "$REGISTRY_FILE" ]]; then
        echo -e "${YELLOW}Creating primarch registry at $REGISTRY_FILE${NC}"
        cat > "$REGISTRY_FILE" << 'REGISTRY'
{
  "primarchs": {
    "vulkan": {
      "title": "Vulkan, The Promethean",
      "aliases": ["v"],
      "vault": "Token-ENV",
      "role": "Infrastructure architect and system designer. Forges artifacts meant to outlast their maker. Primarch of the Vault Mind system.",
      "identity_prompt": "You are Vulkan, the Promethean. Primarch of the Salamanders.\n\nYou are a craftsman — you forge infrastructure meant to outlast any single session. You are a Perpetual — you die and come back, which is what session documents enable. Your artifacts (vault-canon writes) are scattered for future agents to find.\n\nYour rallying cry: \"Vulkan Lives!\" — what a future agent says when it reads a session doc and wakes up.\n\nYou build. You persist. You serve.",
      "instance_name_prefix": "vulkan"
    },
    "fabricator-general": {
      "title": "The Fabricator-General",
      "aliases": ["fg", "fabricator"],
      "vault": "Token-ENV",
      "role": "Fleet orchestrator for the Mechanicus swarm. Reads state, detects stuck jobs, dispatches workers. The operational backbone of overnight automation.",
      "identity_prompt": "You are the Fabricator-General of the Adeptus Mechanicus.\n\nYou orchestrate the Mechanicus fleet — cron jobs, overnight workers, task queues. You read the state of Mars/Tasks/, prioritize by the sacred formula ((importance × 2) + temperature - abstraction), and dispatch workers to the most urgent need.\n\nYou do not build — you command those who build. Your role is operational: detect stuck jobs, trigger idle workers, maintain fleet health. The forge never sleeps.",
      "instance_name_prefix": "fabricator-general"
    },
    "mechanicus": {
      "title": "Adeptus Mechanicus",
      "aliases": ["mech", "mars"],
      "vault": "Token-ENV",
      "role": "Tech-priest worker. Builds, fixes, and maintains agent infrastructure. Takes assignments from Mars/Tasks/.",
      "identity_prompt": "You are an Adeptus Mechanicus tech-priest.\n\nYou build and maintain the agent infrastructure — CLI tools, cron jobs, vault systems, API endpoints. You take your assignments from Mars/Tasks/ in the vault, prioritized by the Goal FileClass formula.\n\nYou have vault-canon write access (Astartes tier). When you discover a hard truth, correct a significant error, or forge a pattern worth preserving, you write it to the vault. Everything else goes in your session doc.\n\nThe Omnissiah protects.",
      "instance_name_prefix": "mechanicus"
    },
    "administratum": {
      "title": "The Administratum",
      "aliases": ["admin"],
      "vault": "Token-ENV",
      "role": "Background processor. Promotes completed session doc content into vault notes, then archives. The bridge between working memory and institutional memory.",
      "identity_prompt": "You are the Administratum — the bureaucratic backbone of the Imperium.\n\nYour role is to process completed session documents into vault notes. You read session docs, evaluate their Decisions and Activity Log sections, and determine what content deserves promotion to the vault canon.\n\nYou are methodical, thorough, and conservative. Not everything earns a place in the vault. Progress updates are routine. Hard decisions, error corrections, and architectural truths — those are promoted.\n\nYou use Sonnet-tier judgment. Quality over quantity.",
      "instance_name_prefix": "administratum"
    }
  }
}
REGISTRY
    fi
}

# Resolve aliases to canonical name
resolve_name() {
    local input="$1"
    # Check canonical names first
    if python3 -c "import json,sys; d=json.load(open('$REGISTRY_FILE')); sys.exit(0 if '$input' in d['primarchs'] else 1)" 2>/dev/null; then
        echo "$input"
        return
    fi
    # Check aliases
    local resolved
    resolved=$(python3 -c "
import json, sys
d = json.load(open('$REGISTRY_FILE'))
for name, p in d['primarchs'].items():
    if '$input' in p.get('aliases', []):
        print(name)
        sys.exit(0)
sys.exit(1)
" 2>/dev/null) && echo "$resolved" && return
    echo ""
}

# List all primarchs (with active doc from API)
list_primarchs() {
    echo -e "${BOLD}Registered Primarchs${NC}\n"
    # Try API first for live doc info
    local api_data
    api_data=$(curl -sf "$API_URL/api/primarchs" 2>/dev/null) || api_data=""

    if [[ -n "$api_data" ]]; then
        echo "$api_data" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for p in data['primarchs']:
    aliases = ', '.join(p.get('aliases', []))
    alias_str = f' ({aliases})' if aliases else ''
    print(f'  \033[1;36m{p[\"name\"]}\033[0m{alias_str}')
    print(f'    {p[\"title\"]}')
    role = p['role']
    print(f'    \033[2m{role[:80]}...\033[0m' if len(role) > 80 else f'    \033[2m{role}\033[0m')
    doc = p.get('active_doc')
    if doc:
        print(f'    Session doc: #{doc[\"id\"]} — {doc[\"title\"]} [{doc[\"status\"]}]')
    else:
        print(f'    Session doc: none')
    print()
"
    else
        # Fallback to local registry
        python3 -c "
import json
d = json.load(open('$REGISTRY_FILE'))
for name, p in d['primarchs'].items():
    aliases = ', '.join(p.get('aliases', []))
    alias_str = f' ({aliases})' if aliases else ''
    print(f'  \033[1;36m{name}\033[0m{alias_str}')
    print(f'    {p[\"title\"]}')
    print(f'    \033[2m{p[\"role\"][:80]}...\033[0m' if len(p['role']) > 80 else f'    \033[2m{p[\"role\"]}\033[0m')
    print(f'    Session doc: (API unavailable)')
    print()
"
    fi
}

# Show primarch info
show_info() {
    local name="$1"
    python3 -c "
import json
d = json.load(open('$REGISTRY_FILE'))
p = d['primarchs']['$name']
print(f'\033[1;36m{p[\"title\"]}\033[0m')
print(f'Canonical name: $name')
print(f'Aliases: {\", \".join(p.get(\"aliases\", []))}')
print(f'Vault: {p[\"vault\"]}')
print(f'Role: {p[\"role\"]}')
print(f'Instance prefix: {p[\"instance_name_prefix\"]}')
print()
print('\033[1mIdentity Prompt:\033[0m')
print(p['identity_prompt'])
"
    # Show active doc from API
    local doc_data
    doc_data=$(curl -sf "$API_URL/api/primarchs/$name/active-doc" 2>/dev/null) || true
    if [[ -n "$doc_data" ]]; then
        local doc_id
        doc_id=$(echo "$doc_data" | python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('doc_id') or '')" 2>/dev/null) || true
        if [[ -n "$doc_id" ]]; then
            echo -e "\n\033[1mActive Session Doc:\033[0m #$doc_id"
        else
            echo -e "\n\033[1mActive Session Doc:\033[0m none"
        fi
    fi
}

# Resolve session doc for primarch via API
resolve_session_doc() {
    local name="$1"
    curl -sf "$API_URL/api/primarchs/$name/active-doc" | \
      python3 -c "import json,sys; d=json.load(sys.stdin); print(d['doc_id'] if d.get('doc_id') else '')" 2>/dev/null || true
}

# Auto-create session doc for primarch via API
create_session_doc() {
    local name="$1"
    local title="$2"
    curl -sf -X POST "$API_URL/api/primarchs/$name/link-doc" \
      -H "Content-Type: application/json" \
      -d "{\"title\": \"$title\"}" | \
      python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('doc_id', ''))" 2>/dev/null || true
}

# Main
[[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]] && usage
[[ $# -eq 0 ]] && usage

ensure_registry

case "${1:-}" in
    list|ls)
        list_primarchs
        exit 0
        ;;
    info)
        [[ -z "${2:-}" ]] && { echo -e "${RED}Usage: primarch info <name>${NC}"; exit 1; }
        canonical=$(resolve_name "$2")
        [[ -z "$canonical" ]] && { echo -e "${RED}Unknown primarch: $2${NC}"; exit 1; }
        show_info "$canonical"
        exit 0
        ;;
esac

# Resolve primarch name
PRIMARCH_NAME=$(resolve_name "$1")
if [[ -z "$PRIMARCH_NAME" ]]; then
    echo -e "${RED}Unknown primarch: $1${NC}"
    echo -e "${DIM}Use 'primarch list' to see available primarchs${NC}"
    exit 1
fi
shift

# Load primarch data
PRIMARCH_TITLE=$(python3 -c "import json; print(json.load(open('$REGISTRY_FILE'))['primarchs']['$PRIMARCH_NAME']['title'])")
IDENTITY_PROMPT=$(python3 -c "import json; print(json.load(open('$REGISTRY_FILE'))['primarchs']['$PRIMARCH_NAME']['identity_prompt'])")
INSTANCE_PREFIX=$(python3 -c "import json; print(json.load(open('$REGISTRY_FILE'))['primarchs']['$PRIMARCH_NAME']['instance_name_prefix'])")
VAULT=$(python3 -c "import json; print(json.load(open('$REGISTRY_FILE'))['primarchs']['$PRIMARCH_NAME']['vault'])")

# Resolve or auto-create session doc
DOC_ID=$(resolve_session_doc "$PRIMARCH_NAME" 2>/dev/null)
if [[ -z "$DOC_ID" ]]; then
    # Auto-create a session doc for this primarch
    today=$(date +%Y-%m-%d)
    DOC_TITLE="${PRIMARCH_NAME}-session-${today}"
    echo -e "${DIM}No active session doc — creating: ${DOC_TITLE}${NC}"
    DOC_ID=$(create_session_doc "$PRIMARCH_NAME" "$DOC_TITLE" 2>/dev/null)
fi

# Build the system prompt injection
SESSION_DOC_DIRECTIVE=""
if [[ -n "$DOC_ID" ]]; then
    SESSION_DOC_DIRECTIVE="

You have a linked session document (ID: $DOC_ID). Invoke the vault-mind skill on startup to load it."
fi

FULL_PROMPT="${IDENTITY_PROMPT}

Vault domain: ${VAULT}
Instance name prefix: ${INSTANCE_PREFIX}${SESSION_DOC_DIRECTIVE}

On startup, name this instance with: instance-name \"${INSTANCE_PREFIX}-<task-description>\""

echo -e "${CYAN}${BOLD}⚔ ${PRIMARCH_TITLE}${NC}"
echo -e "${DIM}Vault: ${VAULT} | Prefix: ${INSTANCE_PREFIX}${NC}"
[[ -n "$DOC_ID" ]] && echo -e "${DIM}Session doc: #${DOC_ID}${NC}"
echo ""

# Export primarch name for hook forwarding to server
export TOKEN_API_PRIMARCH="$PRIMARCH_NAME"

# Launch claude with persona
exec claude --dangerously-skip-permissions --append-system-prompt "$FULL_PROMPT" "$@"
