#!/usr/bin/env bash
# Primarch Launcher - Start Claude sessions with persona identity and session doc
# TAGS: instance, vault-mind, primarch
# AUDIENCE: user
#
# Usage: primarch <name> [claude-flags...]
#        primarch list
#        primarch info <name>
#
# Examples:
#   primarch vulkan                    # Launch as Vulkan
#   primarch fg                        # Launch as Fabricator-General
#   primarch vulkan -p "do the thing"  # Non-interactive with persona
#   primarch list                      # Show all primarchs

set -euo pipefail

API_URL="${TOKEN_API_URL:-http://100.95.109.23:7777}"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
NC='\033[0m'

usage() {
    cat << 'EOF'
Primarch Launcher - Start Claude sessions with persona identity

Usage:
  primarch <name> [claude-flags...]    Launch Claude as a Primarch
  primarch list                        List all registered Primarchs
  primarch info <name>                 Show Primarch details

Primarchs:
  Each Primarch has an identity, a vault domain, and a linked session doc
  managed via the token-api. The identity prompt is stored in the Obsidian
  vault and loaded via the vault-mind skill on startup.

Aliases:
  Short names are supported (e.g., 'fg' for 'fabricator-general').

Examples:
  primarch vulkan                      Interactive session as Vulkan
  primarch fg                          Interactive session as Fabricator-General
  primarch vulkan --model sonnet       Use specific model
  primarch fg -p "check fleet status"  Non-interactive
EOF
    exit 0
}

# Fetch primarch data from API (resolves aliases server-side)
fetch_primarch() {
    local name="$1"
    local data
    data=$(curl -sf "$API_URL/api/primarchs/$name" 2>/dev/null) || {
        echo -e "${RED}Failed to fetch primarch '$name' from API${NC}" >&2
        echo -e "${DIM}Is token-api running? Check: token-ping health${NC}" >&2
        return 1
    }
    echo "$data"
}

# Read identity prompt from vault note's ## System Prompt section
read_identity_prompt() {
    local vault="$1"
    local vault_note_path="$2"

    # Resolve vault to filesystem path
    local vault_root="$HOME/$vault"
    if [[ ! -d "$vault_root" ]]; then
        vault_root="$HOME/Documents/$vault"
    fi
    local full_path="$vault_root/$vault_note_path"
    if [[ ! -f "$full_path" ]]; then
        echo ""
        return
    fi

    # Extract ## System Prompt section (everything between ## System Prompt and the next ##)
    python3 -c "
import sys
with open('$full_path') as f:
    lines = f.read().split('\n')
in_section = False
result = []
for line in lines:
    if line.strip() == '## System Prompt':
        in_section = True
        continue
    elif in_section and line.startswith('## '):
        break
    elif in_section:
        result.append(line)
# Strip leading/trailing blank lines
while result and not result[0].strip():
    result.pop(0)
while result and not result[-1].strip():
    result.pop()
print('\n'.join(result))
"
}

# List all primarchs (from API)
list_primarchs() {
    echo -e "${BOLD}Registered Primarchs${NC}\n"
    local api_data
    api_data=$(curl -sf "$API_URL/api/primarchs" 2>/dev/null) || {
        echo -e "${RED}Failed to reach API. Is token-api running?${NC}"
        exit 1
    }

    echo "$api_data" | python3 -c "
import json, sys
data = json.load(sys.stdin)
for p in data['primarchs']:
    aliases = ', '.join(p.get('aliases', []))
    alias_str = f' ({aliases})' if aliases else ''
    print(f'  \033[1;36m{p[\"name\"]}\033[0m{alias_str}')
    print(f'    {p[\"title\"]}')
    role = p['role']
    print(f'    \033[2m{role[:80]}...\033[0m' if len(role) > 80 else f'    \033[2m{role}\033[0m')
    doc = p.get('active_doc')
    if doc:
        print(f'    Session doc: #{doc[\"id\"]} — {doc[\"title\"]} [{doc[\"status\"]}]')
    else:
        print(f'    Session doc: none')
    print()
"
}

# Show primarch info
show_info() {
    local data="$1"
    echo "$data" | python3 -c "
import json, sys
p = json.load(sys.stdin)
print(f'\033[1;36m{p[\"title\"]}\033[0m')
print(f'Canonical name: {p[\"name\"]}')
print(f'Aliases: {\", \".join(p.get(\"aliases\", []))}')
print(f'Vault: {p[\"vault\"]}')
print(f'Role: {p[\"role\"]}')
print(f'Instance prefix: {p[\"instance_name_prefix\"]}')
print(f'Vault note: {p.get(\"vault_note_path\", \"none\")}')
doc = p.get('active_doc')
if doc:
    print(f'\n\033[1mActive Session Doc:\033[0m #{doc[\"id\"]} — {doc[\"title\"]} [{doc[\"status\"]}]')
else:
    print(f'\n\033[1mActive Session Doc:\033[0m none')
"
}

# Resolve session doc for primarch via API
resolve_session_doc() {
    local name="$1"
    curl -sf "$API_URL/api/primarchs/$name/active-doc" | \
      python3 -c "import json,sys; d=json.load(sys.stdin); print(d['doc_id'] if d.get('doc_id') else '')" 2>/dev/null || true
}

# Auto-create session doc for primarch via API
create_session_doc() {
    local name="$1"
    local title="$2"
    curl -sf -X POST "$API_URL/api/primarchs/$name/link-doc" \
      -H "Content-Type: application/json" \
      -d "{\"title\": \"$title\"}" | \
      python3 -c "import json,sys; d=json.load(sys.stdin); print(d.get('doc_id', ''))" 2>/dev/null || true
}

# Main
[[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]] && usage
[[ $# -eq 0 ]] && usage

case "${1:-}" in
    list|ls)
        list_primarchs
        exit 0
        ;;
    info)
        [[ -z "${2:-}" ]] && { echo -e "${RED}Usage: primarch info <name>${NC}"; exit 1; }
        data=$(fetch_primarch "$2") || exit 1
        show_info "$data"
        exit 0
        ;;
esac

# Fetch primarch data from API (resolves aliases server-side)
PRIMARCH_DATA=$(fetch_primarch "$1") || exit 1
shift

# Extract fields
PRIMARCH_NAME=$(echo "$PRIMARCH_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['name'])")
PRIMARCH_TITLE=$(echo "$PRIMARCH_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['title'])")
INSTANCE_PREFIX=$(echo "$PRIMARCH_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['instance_name_prefix'])")
VAULT=$(echo "$PRIMARCH_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin)['vault'])")
VAULT_NOTE_PATH=$(echo "$PRIMARCH_DATA" | python3 -c "import json,sys; print(json.load(sys.stdin).get('vault_note_path') or '')")

# Read identity prompt from vault note
IDENTITY_PROMPT=""
if [[ -n "$VAULT_NOTE_PATH" ]]; then
    IDENTITY_PROMPT=$(read_identity_prompt "$VAULT" "$VAULT_NOTE_PATH")
fi
if [[ -z "$IDENTITY_PROMPT" ]]; then
    echo -e "${YELLOW}Warning: No identity prompt found in vault note ${VAULT}/${VAULT_NOTE_PATH}${NC}"
    echo -e "${DIM}Add a '## System Prompt' section to the vault note${NC}"
    IDENTITY_PROMPT="You are ${PRIMARCH_TITLE}."
fi

# Resolve or auto-create session doc
DOC_ID=$(resolve_session_doc "$PRIMARCH_NAME" 2>/dev/null)
if [[ -z "$DOC_ID" ]]; then
    # Auto-create a session doc for this primarch
    today=$(date +%Y-%m-%d)
    DOC_TITLE="${PRIMARCH_NAME}-session-${today}"
    echo -e "${DIM}No active session doc — creating: ${DOC_TITLE}${NC}"
    DOC_ID=$(create_session_doc "$PRIMARCH_NAME" "$DOC_TITLE" 2>/dev/null)
fi

# Build the system prompt injection
SESSION_DOC_DIRECTIVE=""
if [[ -n "$DOC_ID" ]]; then
    SESSION_DOC_DIRECTIVE="

You have a linked session document (ID: $DOC_ID). Invoke the vault-mind skill on startup to load it."
fi

FULL_PROMPT="${IDENTITY_PROMPT}

Vault domain: ${VAULT}
Instance name prefix: ${INSTANCE_PREFIX}${SESSION_DOC_DIRECTIVE}

On startup, name this instance with: instance-name \"${INSTANCE_PREFIX}-<task-description>\""

echo -e "${CYAN}${BOLD}${PRIMARCH_TITLE}${NC}"
echo -e "${DIM}Vault: ${VAULT} | Prefix: ${INSTANCE_PREFIX}${NC}"
[[ -n "$DOC_ID" ]] && echo -e "${DIM}Session doc: #${DOC_ID}${NC}"
echo ""

# Export primarch name for hook forwarding to server
export TOKEN_API_PRIMARCH="$PRIMARCH_NAME"

# Launch claude with persona
exec claude --dangerously-skip-permissions --append-system-prompt "$FULL_PROMPT" "$@"
